{
	email {$ACME_EMAIL}
}

{$JIANWEI_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; connect-src 'self'; object-src 'none'; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	reverse_proxy web:3000 {
		# Strip any X-Forwarded-* / X-Real-IP / True-Client-IP headers that the
		# client may have injected. Caddy is the trusted edge and will set its
		# own X-Forwarded-For based on the actual client address.
		header_up -X-Real-IP
		header_up -True-Client-IP
		# X-Forwarded-For is managed by Caddy's trusted_proxies; do not delete
		# it here — Caddy will overwrite or append depending on configuration.
	}
}
