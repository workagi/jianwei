{
  "name": "jianwei",
  "version": "0.1.0",
  "private": true,
  "description": "把 X、微信公众号、全网搜索、榜单和 RSS 整理成一条值得读的中文信息流。",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skymao2021/jianwei.git"
  },
