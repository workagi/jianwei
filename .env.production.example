# Copy to `.env.production` on the server and replace every `change-me-*`.
# Start production with:
#   docker compose --env-file .env.production -p signaldeck -f docker-compose.prod.yml up -d --build

# --- Public domain / HTTPS ---------------------------------------------
# Point this domain's A/AAAA record to the server first. Caddy will request
# Let's Encrypt certificates automatically.
SIGNALDECK_DOMAIN=signal.example.com
ACME_EMAIL=admin@example.com

# --- Required secrets ---------------------------------------------------
# Generate examples:
#   openssl rand -base64 32   # APP_ENCRYPTION_KEY
#   openssl rand -hex 32      # ADMIN_PASSWORD / ADMIN_API_TOKEN / refresh token
POSTGRES_PASSWORD=change-me-postgres-password
APP_ENCRYPTION_KEY=change-me-32-byte-base64-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_API_TOKEN=change-me-admin-token
TRENDRADAR_REFRESH_TOKEN=change-me-trendradar-refresh-token

# --- X / Twitter --------------------------------------------------------
X_BEARER_TOKEN=

# --- Web search providers ----------------------------------------------
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
X_BRAVE_MONTHLY_BUDGET_USD=35

# --- WeRSS --------------------------------------------------------------
# In production, keep WeRSS private. Use SSH tunnel for the authorization UI:
#   ssh -L 8001:127.0.0.1:8001 <user>@<server>
WERSS_ACCESS_KEY=

# --- TrendRadar ---------------------------------------------------------
TRENDRADAR_CRON_SCHEDULE=*/30 * * * *

# --- Worker -------------------------------------------------------------
WORKER_POLL_INTERVAL_SECONDS=60

# --- Model API defaults (optional; can also be configured in admin UI) ---
SUMMARY_PROVIDER=
SUMMARY_BASE_URL=
SUMMARY_API_KEY=
SUMMARY_SKIP_PLATFORMS=wechat
SUMMARY_MODEL=
SUMMARY_TIMEOUT_SECONDS=20
SUMMARY_MAX_CONCURRENCY=4

# --- TrendRadar AI report sidecar compatibility (optional) --------------
AI_ANALYSIS_ENABLED=false
AI_API_KEY=
AI_MODEL=
AI_API_BASE=
