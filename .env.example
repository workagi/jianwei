# --- Database (required) ------------------------------------------------
# Postgres 应用密码。部署前务必改成强密码（默认 monitor 仅限本地）。
# 该值通过 docker-compose 注入 postgres 容器以及 web/worker/migrate 的 DATABASE_URL。
POSTGRES_PASSWORD=change-me-to-a-strong-password
# 本地直连示例（compose 内部已自动使用上面的 POSTGRES_PASSWORD，无需手动同步）；
# 若改了 POSTGRES_PASSWORD，本地 psql 直连时请填同一密码。
DATABASE_URL=postgres://monitor:change-me-to-a-strong-password@localhost:54329/monitor

# --- App ----------------------------------------------------------------
# 预留密钥：当前版本尚未启用连接器凭证加密（connector_credentials 表已建但未写入），
# 保留该变量以备后续版本使用，上线无需特意为它设置强值。
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# --- Admin auth (recommended) ------------------------------------------
# 管理员访问令牌。start.sh 首次启动会自动生成随机令牌并写入本文件；
# 一旦设置，所有写操作（创建/编辑/删除监控、校验配置）与管理后台 /admin
# 都需携带该令牌（写操作用 Authorization: Bearer，/admin 用令牌登录页）。
# 置空或删除该行可关闭鉴权（仅适合本机/内网使用）。
ADMIN_API_TOKEN=__GENERATE__

# --- X (Twitter) official API ------------------------------------------
# Bearer token from https://developer.x.com
X_BEARER_TOKEN=

# --- Budget (optional) --------------------------------------------------
# Combined monthly spend cap (USD) shared by X + Brave. Tavily / Serper calls
# are recorded as usage count first, but not estimated as USD in this variable.
# When exceeded the worker stops billing platforms and marks runs BUDGET_EXHAUSTED.
# Empty / unset = no cap. (Worker reads this exact name.)
X_BRAVE_MONTHLY_BUDGET_USD=35

# --- Brave Search API ---------------------------------------------------
BRAVE_SEARCH_API_KEY=

# --- Optional web search providers -------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=

# --- WeRSS sidecar (WeChat Official Account RSS) -----------------------
WERSS_BASE_URL=http://localhost:8001
# Access Key for rachelos/we-mp-rss (sent as `Authorization: Bearer <AK>`).
WERSS_ACCESS_KEY=

# --- TrendRadar sidecars ------------------------------------------------
TRENDRADAR_MCP_URL=http://localhost:3333/mcp
TRENDRADAR_WEBSERVER_PORT=8088
TRENDRADAR_CRON_SCHEDULE="*/30 * * * *"

# --- Collector worker ---------------------------------------------------
# Seconds between worker polling cycles (default 60).
WORKER_POLL_INTERVAL_SECONDS=60
# Consecutive collection failures before a monitor is auto-disabled.
# Set to 0 to disable this circuit breaker.
WORKER_DISABLE_MONITOR_AFTER_FAILURES=5
# Worker writes this heartbeat file after each polling cycle; Docker healthcheck
# marks the worker unhealthy if it is stale for too long.
WORKER_HEARTBEAT_FILE=/tmp/signaldeck-worker-heartbeat
WORKER_HEALTHCHECK_STALE_SECONDS=600

# --- 模型 API（可选）---------------------------------------------------
# 采集落库时自动生成「读完全文后的内容摘要」、内容类型和主题标签。
# 默认未启用，采集链路行为完全不变。
# 【推荐】直接去后台「平台连接 → 模型 API」面板填写 provider + Base URL + API Key 即可，保存后即刻生效，无需改文件。
# 以下环境变量仅作兜底/默认（后台未配置时使用）。DeepSeek / 火山方舟 / OpenAI / 自定义兼容服务
# 统一走 OpenAI-compatible `/chat/completions`；Claude 走 Anthropic Messages API。
# 后台启用后：新文章自动生成摘要、内容类型和主题标签；微信公众号需在面板勾选「微信公众号也使用模型 API」（会逐篇抓取全文，~22s/篇）。
SUMMARY_PROVIDER=
SUMMARY_BASE_URL=
SUMMARY_API_KEY=
# 跳过不调用模型 API 的平台（默认 wechat：列表无正文，避免为"微信引子式"短摘要消耗模型调用）。置空=全部平台都调用。
SUMMARY_SKIP_PLATFORMS=wechat
# 模型名：deepseek 默认 deepseek-v4-flash；openai 默认 gpt-4o-mini；
# 火山方舟 / 自定义兼容服务建议填写自己的模型 ID 或推理接入点 ID。
SUMMARY_MODEL=
# 单篇内容理解超时秒（默认 20）；批处理并发数（默认 4）。
SUMMARY_TIMEOUT_SECONDS=20
SUMMARY_MAX_CONCURRENCY=4
