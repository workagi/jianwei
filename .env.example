# --- Database (required) ------------------------------------------------
# Postgres 应用密码。部署前务必改成强密码（默认 monitor 仅限本地）。
# 该值通过 docker-compose 注入 postgres 容器以及 web/worker/migrate 的 DATABASE_URL。
POSTGRES_PASSWORD=change-me-to-a-strong-password
# 本地直连示例（compose 内部已自动使用上面的 POSTGRES_PASSWORD，无需手动同步）；
# 若改了 POSTGRES_PASSWORD，本地 psql 直连时请填同一密码。
DATABASE_URL=postgres://monitor:change-me-to-a-strong-password@localhost:54329/monitor

# --- App ----------------------------------------------------------------
# 用于加密后台保存的模型、搜索、X 与 WeRSS API 密钥。必须是 32 字节 Base64；
# 可用 `openssl rand -base64 32` 生成。启用后不要直接更换，否则旧密文无法解密。
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# --- Admin auth (recommended) ------------------------------------------
# 管理后台使用账号密码登录。start.sh 首次启动会自动生成随机初始密码；
# 登录后可在后台修改，修改结果以加盐哈希保存。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__GENERATE__
# 程序写接口使用独立 Bearer Token；不用于网页登录，也不要与登录密码复用。
# start.sh 首次启动会自动生成。
ADMIN_API_TOKEN=__GENERATE__
# 部署在 HTTP（非 HTTPS）时，设为 false 避免浏览器拒绝登录 Cookie。
SECURE_COOKIE=true
ADMIN_SESSION_SECRET=__GENERATE__

# --- X (Twitter) official API ------------------------------------------
# Bearer token from https://developer.x.com
X_BEARER_TOKEN=

# --- Budget (optional) --------------------------------------------------
# Combined monthly spend cap (USD) shared by X + Brave. Tavily / Serper calls
# are recorded as usage count first, but not estimated as USD in this variable.
# When exceeded the worker stops billing platforms and marks runs BUDGET_EXHAUSTED.
# Empty / unset = no cap. (Worker reads this exact name.)
X_BRAVE_MONTHLY_BUDGET_USD=35

# --- Brave Search API ---------------------------------------------------
BRAVE_SEARCH_API_KEY=

# --- Optional web search providers -------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=

# --- WeRSS sidecar (WeChat Official Account RSS) -----------------------
# 默认在上游镜像之上构建见微的单账号授权守护层；需要固定版本时修改上游镜像。
WERSS_UPSTREAM_IMAGE=ghcr.io/rachelos/we-mp-rss:latest
# 可选：改用已经构建并推送的兼容镜像。本地保持为空即可。
WERSS_IMAGE=
WERSS_BASE_URL=http://localhost:8001
# 见微后台“管理授权”按钮跳转地址；线上部署可改成反向代理地址或 SSH 隧道入口。
WERSS_ADMIN_URL=http://localhost:8001/wechat-status
# Access Key for rachelos/we-mp-rss，格式为 AK:SK。
WERSS_ACCESS_KEY=
# 见微会自动把后台启用的公众号同步成一个错峰采集任务。
WERSS_COLLECTION_CRON="17 */3 * * *"
# 超过此小时数仍未同步时，后台标记“公众号源停更”，不再把旧列表误报为成功。
WERSS_MAX_FEED_STALE_HOURS=8
# 每隔多少小时检查一次授权；不足多少小时到期时才启动浏览器静默续期。
WERSS_AUTH_CHECK_INTERVAL_HOURS=6
WERSS_AUTH_REFRESH_BEFORE_HOURS=48

# 公众号正文兜底：默认先尝试免登录公开文章直连。增强备用采集器为可选项，
# 不配置地址就不会调用，也不会要求第二次扫码。
WECHAT_DIRECT_FALLBACK_ENABLED=true
WECHAT_FALLBACK_BASE_URL=
# 可选增强采集器的本机登录端口。启动命令：
# docker compose --profile wechat-fallback up -d wechat-fallback
# 扫码地址：http://localhost:5055/login.html（避开 macOS AirPlay 常占用的 5000 端口）
# 扫码完成后，推荐在后台“平台连接 → 公众号全文通道”填写 http://wechat-fallback:5000。
WECHAT_FALLBACK_PORT=5055
WECHAT_FALLBACK_PUBLIC_URL=http://localhost:5055
# 见微后台“管理授权”按钮跳转地址。
WECHAT_FALLBACK_ADMIN_URL=http://localhost:5055/admin.html
# 仅扫码期间如需让独立浏览器网络访问，可临时改为 0.0.0.0；扫码后恢复 127.0.0.1。
WECHAT_FALLBACK_BIND_HOST=127.0.0.1


# ---- WeRSS/TrendRadar/WeChat Fallback 端口绑定 ----------------------------
# 本地开发默认 127.0.0.1（仅本机访问）。远程部署时改为 0.0.0.0 允许外网访问。
WERSS_BIND_HOST=127.0.0.1
TRENDRADAR_BIND_HOST=127.0.0.1
TRENDRADAR_MCP_BIND_HOST=127.0.0.1
WECHAT_FALLBACK_BIND_HOST=127.0.0.1
# --- TrendRadar sidecars ------------------------------------------------
TRENDRADAR_MCP_URL=http://localhost:3333/mcp
TRENDRADAR_WEBSERVER_PORT=8088
TRENDRADAR_CRON_SCHEDULE="*/30 * * * *"

# --- SuperGrok / X Search (x_grok monitors) -----------------------------
# Each enabled X account poll = 1 Responses API call with the x_search tool.
# Defaults favour quota over "fetch everything every hour".
# Model: prefer a non-reasoning tool-calling model. Override if xAI renames it.
XAI_X_SEARCH_MODEL=grok-4-1-fast-non-reasoning
# Max posts requested per collect poll (preview always uses 5).
XAI_X_SEARCH_MAX_POSTS=10
# History window when a monitor has no cursor yet (days).
XAI_X_SEARCH_LOOKBACK_DAYS=2
# Transient retries for 429/5xx (default 2).
XAI_X_SEARCH_ATTEMPTS=2
# Soft daily cap on x_grok_searches across all monitors. 0 = unlimited.
XAI_X_SEARCH_DAILY_BUDGET=200

# --- Collector worker ---------------------------------------------------
# Seconds between worker polling cycles (default 60).
WORKER_POLL_INTERVAL_SECONDS=60
# Database lease for one claimed monitor. Prevents duplicate execution when
# deployments overlap; an interrupted task becomes claimable again after this.
WORKER_MONITOR_LEASE_SECONDS=1800
# Consecutive collection failures before a monitor is auto-disabled.
# Set to 0 to disable this circuit breaker.
WORKER_DISABLE_MONITOR_AFTER_FAILURES=5
# Worker refreshes this heartbeat independently every 15 seconds; Docker
# healthcheck marks the worker unhealthy if it is stale for too long.
WORKER_HEARTBEAT_FILE=/tmp/jianwei-worker-heartbeat
WORKER_HEALTHCHECK_STALE_SECONDS=600

# --- 模型 API（可选）---------------------------------------------------
# 采集落库时自动生成「读完全文后的内容摘要」、内容类型和主题标签。
# 默认未启用，采集链路行为完全不变。
# 【推荐】直接去后台「平台连接 → 模型 API」面板填写 provider + Base URL + API Key 即可，保存后即刻生效，无需改文件。
# 以下环境变量仅作兜底/默认（后台未配置时使用）。DeepSeek / 火山方舟 / OpenAI / 自定义兼容服务
# 统一走 OpenAI-compatible `/chat/completions`；Claude 走 Anthropic Messages API。
# 后台启用后：新文章自动生成摘要、内容类型和主题标签；微信公众号需在面板勾选「微信公众号也使用模型 API」（会逐篇抓取全文，~22s/篇）。
SUMMARY_PROVIDER=
SUMMARY_BASE_URL=
SUMMARY_API_KEY=
# 跳过不调用模型 API 的平台（默认 wechat：列表无正文，避免为"微信引子式"短摘要消耗模型调用）。置空=全部平台都调用。
SUMMARY_SKIP_PLATFORMS=wechat
# 模型名：deepseek 默认 deepseek-v4-flash；openai 默认 gpt-4o-mini；
# 火山方舟 / 自定义兼容服务建议填写自己的模型 ID 或推理接入点 ID。
SUMMARY_MODEL=
# 单篇内容理解超时秒（默认 45）；账号并发上限（默认 4）；RPM 额度保护（留空=不按 RPM 节流）。
# 低额度账号请按服务商页面填写，例如并发 5、RPM 10；系统会自动排队，避免撞限流。
SUMMARY_TIMEOUT_SECONDS=45
SUMMARY_MAX_CONCURRENCY=4
SUMMARY_REQUESTS_PER_MINUTE=
# 多实例共享同一个模型账号时，可显式填写同一限流范围；留空时按 provider + 模型自动生成。
SUMMARY_RATE_LIMIT_KEY=
# 单篇送入模型的最大正文字符数，以及可选的每 100 万 token 美元价格（用于后台成本估算）。
SUMMARY_MAX_INPUT_CHARS=3000
SUMMARY_INPUT_COST_PER_1M_USD=
SUMMARY_OUTPUT_COST_PER_1M_USD=
# 模型理解失败后由 worker 自动重试：默认每 15 分钟最多重试 5 条，单条最多 5 次。
# 只重试明确失败的内容，不会自动扫完整个历史库造成不可控费用。
CONTENT_RETRY_INTERVAL_MINUTES=15
CONTENT_RETRY_BATCH_SIZE=5
CONTENT_ENRICHMENT_BATCH_SIZE=20
CONTENT_RETRY_MAX_ATTEMPTS=5
# 第三方请求预算预留的自动过期时间，用于回收 Worker 异常退出后的额度占位。
BUDGET_RESERVATION_TTL_MINUTES=60
